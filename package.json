{
  "name": "learny",
  "version": "1.0.0",
  "description": "Learny is an AI learning agent for the Filecoin ecosystem with a web interface.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LearnFIL/learny.git"
  },
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
